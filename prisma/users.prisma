enum Origins {
  LOCAL
  GOOGLE
}

model User {
  id                    String        @id @default(uuid())
  email                 String        @unique
  nickname              String?
  password              String?
  origin                Origins       @default(LOCAL)
  avatarUrl             String?       @map("avatar_url")
  birthdate             DateTime?
  purpose               String?
  emailConfirmed        Boolean?      @default(false)
  profileCompleted      Boolean?      @default(false)
  videos                Video[]
  subscription          Subscription?
  createdAt             DateTime?
  resetPasswordToken    String?
  resetPasswordTokenExp DateTime?
  favorites             Favorite[]
  playlists             Playlist[]

  @@map("users")
}
